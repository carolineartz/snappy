{
  "name": "snap",
  "version": "0.3.0",
  "description": "A floating screenshot app for macOS",
  "private": true,
  "main": "build/main.js",
  "author": "Caroline Artz",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.carolineartz.snap",
    "productName": "Snap",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build-native/snap-vision",
        "to": "snap-vision"
      },
      {
        "from": "native/models",
        "to": "models"
      },
      {
        "from": "native/snap-vision/Resources",
        "to": "clip-resources"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": "-",
      "gatekeeperAssess": false,
      "hardenedRuntime": false
    },
    "dmg": {
      "writeUpdateInfo": false
    }
  },
  "scripts": {
    "postinstall": "electron-rebuild -f",
    "dev": "pnpm models:ensure && pnpm build:native && electron-vite dev",
    "build": "pnpm models:ensure && pnpm build:native && electron-vite build",
    "build:native": "mkdir -p build-native && DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer swiftc -O -o build-native/snap-vision native/snap-vision/main.swift native/snap-vision/CLIPTokenizer.swift native/snap-vision/GPT2ByteEncoder.swift native/snap-vision/Utils.swift",
    "models:ensure": "test -f native/models/mobileclip_s1_image.mlpackage/Data/com.apple.CoreML/weights/weight.bin || bash scripts/download-models.sh",
    "models:download": "bash scripts/download-models.sh",
    "test": "vitest --coverage --run",
    "test:watch": "vitest --watch",
    "lint": "biome check --fix",
    "lint:check": "biome check",
    "format": "biome format --fix",
    "package:macos": "pnpm build && electron-builder --mac"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "electron-icns-ex": "^1.0.1",
    "electron-log": "^5.4.3",
    "konva": "^10.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.3",
    "react-router-dom": "^7.13.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
